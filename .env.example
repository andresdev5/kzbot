DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
# Optional: register slash commands to a single guild for instant updates during dev.
# Leave empty to register globally (may take up to 1 hour to propagate).
DISCORD_DEV_GUILD_ID=
BOT_PREFIX=!
# Comma-separated prefix=command pairs. Each prefix routes directly to that command.
# Default if unset: '=speak,$=fish  (so "' hi there" == "<prefix>speak hi there")
BOT_ALIAS_PREFIXES="'=speak,$=fish"
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
POLLY_DEFAULT_VOICE=Joanna
POLLY_DEFAULT_LANGUAGE=en-US
POLLY_MAX_TEXT_LENGTH=1000
CACHE_ENABLED=true
# CACHE_DIR / CACHE_DB_PATH are container-specific; leave unset when running in Docker
# (docker-compose.yml sets CACHE_DIR=/data/cache for the volume mount).
# For local dev outside Docker, defaults are ./cache and ./cache/cache.db.
CACHE_DIR=cache
CACHE_DB_PATH=
# Fish Audio TTS (https://fish.audio)
FISH_AUDIO_API_KEY=
FISH_AUDIO_MODEL=s2-pro
FISH_AUDIO_MAX_TEXT_LENGTH=1000
# Logging level: DEBUG, INFO, ERROR (default INFO)
LOG_LEVEL=INFO
